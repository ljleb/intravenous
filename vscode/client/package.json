{
    "name": "iv-client",
    "displayName": "Intravenous",
    "description": "Live graph inspection for Intravenous workspaces.",
    "version": "0.0.1",
    "publisher": "intravenous",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:.intravenous",
        "onWebviewPanel:intravenous.lanes"
    ],
    "main": "./dist/extension.js",
    "scripts": {
        "build": "node ./esbuild.mjs",
        "watch": "node ./esbuild.mjs --watch",
        "typecheck": "tsc --noEmit -p ./tsconfig.json",
        "test": "tsc -p ./tsconfig.tests.json && node --test dist-test/test/**/*.test.js"
    },
    "dependencies": {
        "reflect-metadata": "^0.2.2",
        "tsyringe": "^4.8.0"
    },
    "devDependencies": {
        "@types/node": "^22.15.31",
        "@types/vscode": "^1.85.0",
        "esbuild": "^0.25.5",
        "typescript": "^5.8.3"
    },
    "contributes": {
        "configuration": {
            "title": "Intravenous",
            "properties": {
                "intravenous.intravenousDir": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to the directory that directly contains the intravenous executable. INTRAVENOUS_DIR takes precedence when set."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "intravenous",
                    "title": "Intravenous",
                    "icon": "media/intravenous.svg"
                }
            ]
        },
        "views": {
            "intravenous": [
                {
                    "id": "intravenous.liveGraph",
                    "name": "Intravenous",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "intravenous.openLanes",
                "title": "Intravenous: Open Lanes"
            }
        ]
    }
}
